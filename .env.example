# ============================================
# MUSICSTORE - Variáveis de ambiente Railway
# Copie este arquivo como referência.
# No Railway, configure em: Settings > Variables
# ============================================

# MySQL — Railway preenche automaticamente ao adicionar o plugin MySQL
MYSQLHOST=your-mysql-host.railway.internal
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your_password
MYSQLDATABASE=railway

# JWT — troque por uma string longa e aleatória
JWT_SECRET=troque_por_uma_chave_secreta_longa_aqui
